{
  "manifest_version": 3,
  "name": "ChatGPT to Google Docs Streamer",
  "version": "1.0",
  "description": "Streams the latest ChatGPT response in real-time to a Google Doc.",
  "permissions": [
    "storage",
    "identity"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://docs.googleapis.com/*"
  ]
}
